{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "environmentName": {
      "value": "${AZURE_ENV_NAME}"
    },
    "location": {
      "value": "${AZURE_LOCATION}"
    },
    "chatModel": {
      "value": "${AZURE_CHAT_MODEL=gpt-5.4-mini}"
    },
    "chatModelVersion": {
      "value": "${AZURE_CHAT_MODEL_VERSION=2026-03-17}"
    },
    "evalModel": {
      "value": "${AZURE_EVAL_MODEL=gpt-5.1}"
    },
    "evalModelVersion": {
      "value": "${AZURE_EVAL_MODEL_VERSION=2025-11-13}"
    },
    "embeddingModel": {
      "value": "${AZURE_EMBEDDING_MODEL=text-embedding-3-large}"
    }
  }
}

